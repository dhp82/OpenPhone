# =============================================================================
# PhoneClaw environment configuration
# Copy this file to .env and fill in your values.
# Usage: source .env  (or use direnv / python-dotenv)
# =============================================================================

# -----------------------------------------------------------------------------
# iOS Device (WebDriverAgent)
# -----------------------------------------------------------------------------
WDA_URL=http://localhost:8100


# =============================================================================
# VLM Backend — choose ONE of the two options below
# =============================================================================

# -----------------------------------------------------------------------------
# Option A: OpenRouter (recommended for cloud models)
#   Get your key at https://openrouter.ai/keys
#   Model list: https://openrouter.ai/models (filter by "Vision" or "Multimodal")
# -----------------------------------------------------------------------------

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Executor model (runs the per-step actions)
# Recommended options:
#   qwen/qwen2.5-vl-72b-instruct      — best open-source vision model
#   openai/gpt-4o                     — strong general-purpose
#   google/gemini-2.0-flash-exp       — fast and capable
#   anthropic/claude-3.5-sonnet       — strong reasoning
OPENROUTER_MODEL=z-ai/glm-4.6v

# Evaluator model (verifies subtask success from screenshots)
# Can be the same as OPENROUTER_MODEL, or a different (stronger) model.
# Falls back to OPENROUTER_MODEL if unset.
EVAL_OPENROUTER_MODEL=z-ai/glm-4.6v


# -----------------------------------------------------------------------------
# Option B: Local / self-hosted OpenAI-compatible VLM
#   (e.g. vLLM, Ollama, LM Studio, etc.)
# -----------------------------------------------------------------------------

# API_BASE=http://localhost:8002/v1
# MODEL_NAME=Qwen/Qwen2.5-VL-72B-Instruct
# API_KEY=EMPTY
# AGENT_TYPE=OpenAIAgent

# Separate evaluator endpoint (optional, falls back to API_BASE/MODEL_NAME)
# EVAL_API_BASE=http://localhost:8003/v1
# EVAL_MODEL_NAME=Qwen/Qwen2.5-VL-72B-Instruct
# EVAL_API_KEY=EMPTY
